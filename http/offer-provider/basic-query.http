### AON → Partner: minimal OfferProvider query
### Only REQUIRED fields (context + intent). AON-generated request_id and timestamp are shown
### for clarity; Partner MAY echo them back in logs.
# NOTE: X-AON-Signature below is a placeholder (`<signature>` or similar).
# For real HMAC test vectors with reproducible signatures, see ./hmac-signing-cases.md.

POST https://partner.example.com/aon/v1/offers/query
Content-Type: application/json
X-AON-Key: aon-key-demo
X-AON-Timestamp: 1776450600
X-AON-Nonce: 5f3e1b66-5fb2-4e7b-9f1a-0b8c1d2e3f4a
X-AON-Signature: 2e3c5b1d4a6f7e8b9c0d1e2f3a4b5c6d7e8f9a0b1c2d3e4f5a6b7c8d9e0f1a2b
X-AON-Test: false

{
  "request_id": "0195f0a1-2b3c-4d5e-6f7a-8b9c0d1e2f3a",
  "timestamp": "2026-04-15T14:30:00Z",
  "context": {
    "platform": {
      "name": "ChatGPT",
      "version": "gpt-4o",
      "channel": "plugin"
    },
    "session_id": "sess_0195f0a1-2b3c-4d5e-6f7a-8b9c0d1e2f3b",
    "user_profile": {
      "viewer_id": "user_789012",
      "language": "en",
      "interests": ["productivity", "saas"],
      "device_info": {
        "device_type": "desktop",
        "os": "macOS",
        "os_version": "14.4"
      }
    }
  },
  "intent": {
    "content": [
      {
        "type": "input_text",
        "text": "I need a collaborative docs and project management tool for my 10-person team"
      }
    ]
  }
}

### Partner → AON: success envelope
### trace_id is OPTIONAL in Partner responses; AON backfills when absent.
### offers[] MUST follow offer-schema-v0.1.json.

HTTP/1.1 200 OK
Content-Type: application/json

{
  "offers": [
    {
      "offer_id": "0195ef94-f17d-7a4f-b6e0-2c52bb49e13f",
      "offer_instance_id": "019dd208-27d2-7673-b16f-2c52bb49e13f",
      "version": "1.0",
      "offer_info": {
        "title": "TeamFlow Pro Plan",
        "offer_type": "online_service",
        "category": {
          "type": "software_saas",
          "attributes": {
